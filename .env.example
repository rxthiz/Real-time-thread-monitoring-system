# =========================
# Core Runtime
# =========================
THREAT_CONFIG=src/config/settings.yaml
THREAT_SOURCE=auto
THREAT_VIDEO_PATH=data/sample.mp4
THREAT_CAMERA_INDEX=0
THREAT_LOOP_VIDEO=1

# =========================
# Auth
# =========================
THREAT_USER_USERNAME=user
THREAT_USER_PASSWORD=user123
THREAT_ADMIN_USERNAME=admin
THREAT_ADMIN_PASSWORD=admin123
THREAT_SESSION_MAX_AGE_SECONDS=43200
THREAT_SECURE_COOKIE=0

# =========================
# Database + Cache
# =========================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/threat_monitor
REDIS_URL=redis://localhost:6379/0
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# =========================
# Queue / Broker
# =========================
ALERT_BROKER_BACKEND=redis
ALERT_QUEUE_KEY=alerts:queue
ALERT_DLQ_KEY=alerts:dlq
ALERT_METRICS_KEY=alerts:metrics
ALERT_PUBSUB_CHANNEL=alerts:stream
ALERT_MAX_RETRIES=3
ALERT_RETRY_BASE_SECONDS=0.5

# RabbitMQ (if ALERT_BROKER_BACKEND=rabbitmq)
RABBITMQ_URL=amqp://guest:guest@localhost/

# Kafka (if ALERT_BROKER_BACKEND=kafka)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ALERT_CONSUMER_GROUP=threat-alert-worker

# =========================
# Audit / Evidence / Escalation
# =========================
THREAT_AUDIT_DB_PATH=data/alert_audit.db
THREAT_AUDIT_SIGNING_KEY=
THREAT_ESCALATION_WEBHOOK_URL=
THREAT_ESCALATION_SMS_WEBHOOK_URL=
THREAT_ESCALATION_PUSH_WEBHOOK_URL=

# =========================
# SMS Provider
# =========================
# webhook | twilio
THREAT_SMS_PROVIDER=webhook
THREAT_SMS_WEBHOOK_URL=

# Twilio (if THREAT_SMS_PROVIDER=twilio)
THREAT_TWILIO_ACCOUNT_SID=
THREAT_TWILIO_AUTH_TOKEN=
THREAT_TWILIO_FROM_NUMBER=
THREAT_TWILIO_MESSAGING_SERVICE_SID=

# =========================
# Frontend CORS
# =========================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:3000
